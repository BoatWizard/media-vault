# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=media_vault
POSTGRES_USER=media_user
POSTGRES_PASSWORD=changeme_strong_password

# ── MinIO object storage ───────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_password
MINIO_BUCKET=media-vault

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_a_real_secret

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave blank for standalone use (browser reaches backend at localhost:8000).
# Set to /api when behind an nginx reverse proxy that strips the /api prefix.
VITE_API_URL=

# ── Metadata API keys (all optional) ──────────────────────────────────────────
# Sources are silently skipped when keys are absent.
# Books are looked up via Open Library + Google Books with no key required.

# IGDB — game metadata (free, requires a free Twitch developer account)
# https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# TMDB — movie & TV metadata (free)
# https://developer.themoviedb.org/docs/getting-started
TMDB_API_KEY=

# OMDb — movie metadata, IMDb-backed (free tier: 1000 req/day)
# https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# ScreenScraper — retro game covers & regional data (free account)
# https://www.screenscraper.fr/membreinscription.php
SCREENSCRAPER_USER=
SCREENSCRAPER_PASSWORD=
