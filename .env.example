# Database
POSTGRES_DB=media_inventory
POSTGRES_USER=media_user
POSTGRES_PASSWORD=changeme_strong_password

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_strong_password
MINIO_BUCKET=media-inventory

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_a_real_secret

# Frontend API URL (what the browser uses to reach the backend)
VITE_API_URL=http://localhost:8000

# CORS origins allowed by the backend (comma-separated in allowed_origins list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ── Metadata API keys (all optional — sources are skipped if keys are absent) ─

# IGDB (games) — free, requires Twitch developer account
# https://api-docs.igdb.com/#getting-started
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# TMDB (movies/TV) — free
# https://developer.themoviedb.org/docs/getting-started
TMDB_API_KEY=

# OMDb (movies, IMDb-backed) — free tier available
# https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# ScreenScraper (retro games, covers, regional data) — free account
# https://www.screenscraper.fr/membreinscription.php
SCREENSCRAPER_USER=
SCREENSCRAPER_PASSWORD=
